rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: own profile get/create/update, admin list/delete
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow list: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'displayName']);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Mountains: authenticated read, admin write
    match /mountains/{mountain} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.admin == true
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Trails: authenticated read, admin write, authenticated user upload (pending)
    match /trails/{trail} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.status == 'pending'
        && request.resource.data.name is string;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Trail reviews: authenticated read, auth create, owner delete
    match /trail_reviews/{review} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Posts: authenticated read, owner write, anyone update interaction counters only
    match /posts/{post} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid
        && request.resource.data.content is string;
      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
        // owner can update anything
        resource.data.authorId == request.auth.uid ||
        // anyone can update only likesCount and commentsCount, nothing else
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount'])
      );
    }

    // Post likes subcollection: auth users write, owner read
    match /posts/{post}/likes/{userId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid;
    }

    // Chat rooms (named collection in Android code): participants only
    match /chat_rooms/{chat} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
    }
    match /chat_rooms/{chat}/messages/{message} {
      allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(chat)).data.participants;
      allow create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chat_rooms/$(chat)).data.participants;
    }

    // Chats (alternative naming): participants only
    match /chats/{chat} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // Chat messages: participants only
    match /chats/{chat}/messages/{message} {
      allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chat)).data.participants;
      allow create: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chat)).data.participants;
    }

    // Articles: admin CRUD
    match /articles/{article} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.admin == true
        && request.resource.data.title is string;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Stats: read by authenticated, write by functions (via admin SDK, bypasses rules)
    match /stats/{stat} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // SOS alerts: auth users can create, read own
    match /sos_alerts/{alert} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Stories: any auth read, owner create/delete, subcollection viewers
    match /stories/{story} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.resource.data.keys().hasOnly(['viewerCount']);
      match /viewers/{viewer} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == viewer;
      }
    }

    // Emergency contacts: owner only
    match /users/{userId}/emergency_contacts/{contact} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }

    // FCM tokens: owner write, functions read
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Summit logs: auth read, verified user create
    match /summit_logs/{log} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
