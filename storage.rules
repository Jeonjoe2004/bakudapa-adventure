rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for mountain images and trail images
    match /mountains/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /trails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // User avatars: owner write & delete, authenticated read
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    // Posts images: owner write, authenticated read
    match /posts/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow write: if request.auth != null;
    }
    // Chat images: authenticated with size limit
    match /chats/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    // Article images: admin write, authenticated read
    match /articles/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    // Stories: owner write, authenticated read
    match /stories/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
      allow write: if request.auth != null;
    }
    // Summit logs: owner write, authenticated read
    match /summit_logs/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024;
      allow write: if request.auth != null;
    }
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
